+    History,
+    Stale,
+}
+
+pub fn classify_session(
+    is_ended: bool,
+    has_live_terminal: bool,
+    has_live_process: bool,
+) -> SessionDisplayState {
+    if is_ended {
+        SessionDisplayState::History
+    } else if has_live_terminal || has_live_process {
+        SessionDisplayState::Active
+    } else {
+        SessionDisplayState::Stale
+    }
