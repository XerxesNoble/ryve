+/// Record the detached child PID so liveness can be checked later.
+pub async fn set_child_pid(
+    pool: &SqlitePool,
+    session_id: &str,
+    child_pid: u32,
+) -> Result<(), SparksError> {
+    sqlx::query("UPDATE agent_sessions SET child_pid = ? WHERE id = ?")
+        .bind(i64::from(child_pid))
+        .bind(session_id)
+        .execute(pool)
+        .await?;
+
+    Ok(())
+}
+
